I $vs } [$ps$ss]? ($sb?) R > ɜː;
I $vs > ɪ;
O $vs } [$ps$ss]? ($sb?) R > ɔː;
O $vs > ɒ;

# reduced vowels

# initial

$wb $sb $c* { A > ə;
$wb $sb $c* { [AO]?E > ɪ;
